{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yolo-tts-app",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../",
    "devUrl": "http://localhost:5000",
    "beforeDevCommand": "echo dev",
    "beforeBuildCommand": "echo build"
  },
  "app": {
    "windows": [
      {
        "title": "YOLO & TTS Analyzer",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
